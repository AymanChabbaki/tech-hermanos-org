PORT=5000
MONGODB_URI=mongodb://localhost:27017/tech-hermanos
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email (SMTP) — use Gmail App Password or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Where team notification emails go (defaults to SMTP_USER if not set)
TEAM_EMAIL=contact@techermanos.org
